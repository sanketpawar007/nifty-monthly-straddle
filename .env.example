# Nifty Monthly Iron Fly Bot — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Kite Connect API (from https://developers.kite.trade)
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Zerodha login credentials (used by Go autologin binary)
KITE_USER_ID=your_zerodha_client_id
KITE_PASSWORD=your_zerodha_password
KITE_TOTP_SECRET=your_totp_secret_base32

# Token file path (written daily by autologin at 08:45 IST)
# ACCESS_TOKEN_FILE=./secrets/kite_access_token   # optional; this is the default

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Strategy
LOTS=1
REENTRY_CAP=1

# Safety
DRY_RUN=true            # Set to false ONLY when ready for live trading
MAX_DAILY_LOSS_RS=20000
